---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | Harris`} description={post.data.description}>
  <article class="post">
    <header class="post-head article-body">
      <p class="kicker">{post.data.pubDate.toLocaleDateString('zh-CN')}</p>
      <h1>{post.data.title}</h1>
      <p class="dek">{post.data.description}</p>
      <ul class="tags">
        {post.data.tags.map((tag) => (
          <li><a href={`/tags/${tag}/`}>{tag}</a></li>
        ))}
      </ul>
    </header>

    <div class="article-body prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    padding-top: 0.5rem;
  }

  .post-head {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--line);
    margin-bottom: 1.5rem;
  }

  h1 {
    font-size: clamp(2.2rem, 5vw, 4rem);
    margin: 0.25rem 0 0.7rem;
  }

  .dek {
    font-size: 1.1rem;
    margin: 0;
  }

  .tags {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tags a {
    display: inline-block;
    text-decoration: none;
    border: 1px solid var(--line);
    padding: 0.2rem 0.55rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
  }

  .prose :global(h2) {
    margin-top: 2rem;
    font-size: 1.8rem;
  }

  .prose :global(p),
  .prose :global(li) {
    font-size: 1.08rem;
  }
</style>
