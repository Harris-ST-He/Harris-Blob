---
import BaseLayout from "../layouts/BaseLayout.astro";

const links = [
  {
    name: "Astro 官网",
    url: "https://astro.build",
    logo: "https://astro.build/favicon.svg",
    description: "一个很适合做内容网站和个人站点的现代静态站点框架。",
  },
];
---

<BaseLayout title="友链 | Harris" description="Harris 的友情链接页。">
  <section class="page-head">
    <p class="kicker">LINKS</p>
    <h1>友链</h1>
    <p class="muted">先放一些我喜欢、也觉得值得一看的站点。</p>
  </section>

  <section class="list">
    {
      links.map((link) => (
        <article class="row">
          <img
            src={link.logo}
            alt={`${link.name} logo`}
            class="logo"
            loading="lazy"
          />
          <div>
            <h2>
              <a href={link.url} target="_blank" rel="noreferrer">
                {link.name}
              </a>
            </h2>
            <p class="url">{link.url}</p>
            <p>{link.description}</p>
          </div>
        </article>
      ))
    }
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--line);
  }

  .page-head h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin: 0.3rem 0;
  }

  .list {
    padding-top: 1rem;
  }

  .row {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--line);
    max-width: 42rem;
  }

  .logo {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.8rem;
    object-fit: contain;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.5);
    padding: 0.45rem;
    flex-shrink: 0;
  }

  .row h2 {
    font-size: 1.4rem;
    margin: 0 0 0.35rem;
  }

  .row h2 a {
    text-decoration: none;
  }

  .url {
    margin: 0 0 0.5rem;
    font-family: var(--font-sans);
    color: var(--accent);
    font-size: 0.92rem;
  }

  @media (max-width: 720px) {
    .row {
      gap: 0.85rem;
    }

    .logo {
      width: 2.5rem;
      height: 2.5rem;
    }
  }
</style>
