---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Harris 的米黄色报纸风博客。',
} = Astro.props;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <main>
      <header class="site-header">
        <p class="kicker">HARRIS</p>
        <div class="masthead">
          <div class="identity">
            <img src="/avatar.jpg" alt="Harris 的头像" class="avatar" />
            <div class="identity-copy">
              <a href="/" class="brand">Harris</a>
              <p class="tagline">这里记录 Harris 的技术思考、写作片段与审美偏好。页面尽量轻，结构尽量稳，让注意力重新回到内容本身。</p>
            </div>
          </div>
        </div>
        <nav class="nav">
          <a href="/">首页</a>
          <a href="/blog">文章</a>
          <a href="/rss.xml">RSS</a>
        </nav>
      </header>
      <slot />
      <footer class="site-footer muted">
        <p>由 Harris 写作，使用 Astro 构建，保持轻量、安静与可读。</p>
      </footer>
    </main>
  </body>
</html>

<style>
  .site-header {
    padding: 2rem 0 1.5rem;
    border-bottom: 1px solid var(--line);
    margin-bottom: 2rem;
  }

  .masthead {
    display: grid;
    gap: 0.4rem;
    margin: 0.35rem 0 1rem;
  }

  .identity {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .identity-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.2rem;
    min-width: 0;
  }

  .avatar {
    width: 3.9rem;
    height: 3.9rem;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
    background: rgba(255, 255, 255, 0.4);
    flex-shrink: 0;
  }

  .brand {
    display: block;
    line-height: 0.95;
    font-size: clamp(2.4rem, 6vw, 4.6rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-decoration: none;
  }

  .tagline {
    margin: 0;
    line-height: 1.3;
    font-family: var(--font-sans);
    color: var(--ink-soft);
  }

  .nav {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 0.8rem;
    border-top: 1px solid var(--line);
    font-family: var(--font-sans);
  }

  .nav a {
    text-decoration: none;
  }

  .site-footer {
    border-top: 1px solid var(--line);
    margin-top: 4rem;
    padding: 1.25rem 0 3rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
  }

  @media (max-width: 720px) {
    .identity {
      align-items: flex-start;
    }

    .avatar {
      width: 4rem;
      height: 4rem;
    }
  }
</style>
